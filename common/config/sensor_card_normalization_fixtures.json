[
  {
    "name": "numeric sensor preserves large numbers",
    "input": "sensor.room_temp;Room Temp;Auto;Auto;sensor.room_temp;deg C;sensor;1;large_numbers,ignored=1",
    "expected": {
      "entity": "sensor.room_temp",
      "label": "Room Temp",
      "icon": "Auto",
      "icon_on": "Auto",
      "sensor": "sensor.room_temp",
      "unit": "deg C",
      "type": "sensor",
      "precision": "1",
      "options": "large_numbers"
    }
  },
  {
    "name": "numeric sensor preserves explicit large number off",
    "input": "sensor.room_temp;Room Temp;Auto;Auto;sensor.room_temp;deg C;sensor;2;large_numbers=off,ignored=1",
    "expected": {
      "entity": "sensor.room_temp",
      "label": "Room Temp",
      "icon": "Auto",
      "icon_on": "Auto",
      "sensor": "sensor.room_temp",
      "unit": "deg C",
      "type": "sensor",
      "precision": "2",
      "options": "large_numbers=off"
    }
  },
  {
