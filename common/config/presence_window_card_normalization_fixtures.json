[
  {
    "name": "door window default normalizes to door",
    "input": "binary_sensor.front_door;Front Door;Auto;Auto;binary_sensor.front_door;ignored;door_window;;active_color,ignored=1",
    "expected": {
      "entity": "",
      "label": "Front Door",
      "icon": "Door",
      "icon_on": "Door Open",
      "sensor": "binary_sensor.front_door",
      "unit": "",
      "type": "door_window",
      "precision": "door",
      "options": "active_color"
    }
  },
  {
